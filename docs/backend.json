{
  "entities": {
    "UserProfile": {
      "title": "UserProfile",
      "description": "Цифровой профиль пользователя с ИИ-анализом личности.",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "name": { "type": "string" },
        "email": { "type": "string" },
        "phone": { "type": "string" },
        "bio": { "type": "string" },
        "personalityProfile": { "type": "string" },
        "personalityVector": { "type": "array", "items": { "type": "number" } },
        "hasCompletedAssessment": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "name", "email"]
    }
  },
  "auth": {
    "providers": ["email"]
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Профили пользователей."
    }
  }
}
