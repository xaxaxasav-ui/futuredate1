rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    match /profiles/{userId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == userId;
      allow delete: if request.auth.uid == userId;
    }
    
    match /likes/{likeId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth.uid == userId || request.auth.uid == likedUserId;
    }
    
    match /matches/{matchId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == userId || request.auth.uid == matchedUserId;
    }
    
    match /messages/{messageId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == senderId;
    }
    
    match /notifications/{notifId} {
      allow read: if request.auth.uid == userId;
      allow create: if request.auth != null;
      allow update: if request.auth.uid == userId;
    }
    
    match /gifts/{giftId} {
      allow read: if request.auth != null;
      allow create: if request.auth != null;
    }
    
    match /profile_views/{viewId} {
      allow read: if request.auth.uid == viewedId;
      allow create: if request.auth != null;
    }
  }
}